# Copiar a .env.local y rellenar valores
# Los correos no se muestran en la web; solo se usan en el servidor.

NEXT_PUBLIC_SITE_URL=https://aura-drop.vercel.app

# Contacto principal: destinatario de contactos y solicitudes de compra
CONTACTO_EMAIL=tu-email@ejemplo.com

# Resend: https://resend.com — API Key para enviar los emails
RESEND_API_KEY=re_xxxxx

# Opcional: copia oculta (BCC) para recibir también una copia en otro correo
# RESEND_BCC=otro-email@ejemplo.com

# Opcional: remitente verificado en Resend (por defecto onboarding@resend.dev)
# RESEND_FROM=contacto@tudominio.com
